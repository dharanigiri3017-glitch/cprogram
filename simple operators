#include <stdio.h>

int main() {
    int a, b;

    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    printf("\nAddition (+): %d", a + b);
    printf("\nSubtraction (-): %d", a - b);
    printf("\nMultiplication (*): %d", a * b);

    if (b != 0)
        printf("\nDivision (/): %d", a / b);
    else
        printf("\nDivision (/): Cannot divide by zero");

    printf("\nModulus (%%): %d", a % b);

    return 0;
}
